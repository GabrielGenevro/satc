if (isset($_GET['ifes'])) {
    $sql = new mysqli('localhost','root','','satc');
    $ifes = mysqli_real_escape_string($sql,$_GET['ifes']);
    $query = "SELECT id, campus FROM tabmpus WHERE instituto = $ifes";
    $ret = $sql->query($query);
    $result = array();
    while ($row = $ret->fetch_assoc()) {
         $result[] = array(
             'value' => $row['id'],
             'name' => $row['campus']
         );
    }
    echo json_encode($result);
}